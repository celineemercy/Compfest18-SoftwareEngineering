generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Define the exact roles required by SEAPEDIA
enum Role {
  ADMIN
  SELLER
  BUYER
  DRIVER
}

// 2. Define the User blueprint
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String   // We will hash this later for security!
  
  // This array bracket [] is the magic. It allows [BUYER, SELLER] at the same time.
  roles     Role[]   

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}