generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  BUYER
  DRIVER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  roles     Role[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
