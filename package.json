{
  "name": "compfest18-softwareengineering",
  "version": "1.0.0",
  "description": "Compfest18 Software Engineering",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "dev:api": "npm --prefix apps/api run start:dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build:api": "npm --prefix apps/api run build",
    "build:web": "npm --prefix apps/web run build",
    "test:api": "npm --prefix apps/api test",
    "lint:api": "npm --prefix apps/api run lint",
    "lint:web": "npm --prefix apps/web run lint",
    "prisma:generate": "npm --prefix apps/api exec prisma generate",
    "prisma:migrate": "npm --prefix apps/api exec prisma migrate dev",
    "db:seed": "npm --prefix apps/api run db:seed",
    "setup:check": "docker compose config --quiet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/celineemercy/Compfest18-SoftwareEngineering.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/celineemercy/Compfest18-SoftwareEngineering/issues"
  },
  "homepage": "https://github.com/celineemercy/Compfest18-SoftwareEngineering#readme"
}
