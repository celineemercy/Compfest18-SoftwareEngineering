# PostgreSQL container credentials.
POSTGRES_USER=seapedia_admin
POSTGRES_PASSWORD=seapedia_secret
POSTGRES_DB=seapedia_db

# API connection string.
# When running locally (API on host machine), use localhost.
# When running via Docker, docker-compose.yaml overrides this automatically to use the 'db' service hostname.
DATABASE_URL="postgresql://seapedia_admin:seapedia_secret@localhost:5432/seapedia_db?schema=public"

# API runtime.
PORT=3000
JWT_SECRET=change-me-in-local-development

# Browser-facing API URL used by the Vite web app.
VITE_API_URL=http://localhost:3000
